# Optional for local Express/SQLite development.
# When this is empty, the frontend calls /api on the same origin.
#
# For Vercel, set this to your Google Apps Script web app URL ending in /exec.
# The Vercel /api proxy also reads this value to avoid browser CORS issues.
VITE_API_BASE_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"

# Optional Vercel server-side alias. If set, this takes priority over VITE_API_BASE_URL
# inside the Vercel /api proxy.
APPS_SCRIPT_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"
